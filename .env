# Auth
SALES_PIN=1234                         # PIN commercial (4 chiffres)
ADMIN_PIN=123456                       # PIN manager (6 chiffres)
SESSION_SECRET=a_very_secret_random_string_replace_me_in_production

# --- Base de Données & Sécurité ---
# Le nom du fichier (Sera créé dans le dossier /data)
DATABASE_NAME=wasla_production.db

# La clé de 32 octets (256-bit) pour le chiffrement AES
# UTILISEZ CETTE CLÉ EXACTE POUR VOS TESTS :
ENCRYPTION_KEY=5d2f8e1a9b3c4d7e6f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e


# Synchronisation
SYNC_ENDPOINT=https://localhost:3000/api/sync
NEXT_PUBLIC_SYNC_ENABLED=true

# App
NEXT_PUBLIC_EVENT_NAME=Salon Demo 2026
NEXT_PUBLIC_COMPANY_NAME=Wasla
NEXT_PUBLIC_APP_PIN=1234               # Exposé côté client pour la validation kiosque
NEXT_PUBLIC_QR_BASE_URL=http://localhost:3000


# /etc/cron.d/wasla-backup  — Daily backup at 02:00
#0 2 * * *  root  curl -s \
#  -H "X-Backup-Key: your-strong-secret-backup-key" \
#  https://your-domain.com/api/backup \
#  -o /var/backups/wasla/wasla_$(date +\%F).sqlite
# Keep only the last 30 days
#find /var/backups/wasla/ -name "*.sqlite" -mtime +30 -delete
BACKUP_SECRET_KEY=your-strong-secret-backup-key